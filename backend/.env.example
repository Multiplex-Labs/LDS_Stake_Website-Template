DEV=false
PORT=8000
# Database configuration
DB_ENGINE=sqlite
## SQLITE settings
DATABASE_PATH=./database.db
# Initial admin user password (used only if no users exist)
## It is reccommended to pass this via environment variable at first launch,
## as opposed to storing it in plaintext here.
## You will be forced to change this password on first login
INITIAL_ADMIN_PASSWORD=admin123
# Authentication settings
JWT_SECRET_KEY=your_secret_key_here
## Whether or nor you have SSL configured for your deployment.
## If you do not have SSL configured, set this to false.
## The default is true for security reasons.
## Refresh tokens will not work if SSL_ENABLED is true but you do not have SSL Enabled.
SSL_ENABLED=true

## Speaking schedule CSV (optional)
# Path to a CSV file used to load speaking assignments for High Councilors.
# The backend reads this file on startup and builds a yearly speaking calendar.
# Expected format:
# - 12 comma-separated columns (January -> December)
# - Each row is a High Councilor slot (slot 1, slot 2, ...). Number of rows
#   must match the `max_slots` value for the `High Councilor` calling in the DB.
# - Cells contain a ward id (integer) or are empty for "not speaking" that month.
# Example path (absolute or relative to the backend working directory):
SPEAKING_SCHEDULE_CSV_PATH=./speaking_schedule.csv
