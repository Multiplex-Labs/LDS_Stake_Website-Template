DEV=false
PORT=8000

# Database configuration
DB_ENGINE=sqlite
SQLALCHEMY_ECHO=false
## Path to the SQLite database file. Use /app/data/database.db when running in Docker.
DATABASE_PATH=/app/data/database.db

# Initial admin user password (required ONLY on first launch when the database is empty).
# A forced password change happens on first login. Remove or leave unset after first login.
INITIAL_ADMIN_PASSWORD=

# Authentication settings
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=

# Discord bot integration
# Token the backend sends to the discordbot via Authorization: Bearer header
DISCORD_BOT_TOKEN=
# Use Docker service name for container deployments; change to http://localhost:8001 for local dev
DISCORD_BOT_URL=http://discordbot:8001

## Whether SSL is configured for your deployment.
## Set to false only for local development without TLS.
SSL_ENABLED=true

## Speaking schedule CSV (optional)
SPEAKING_SCHEDULE_CSV_PATH=./speaking_schedule.csv

# Calling proposal settings
SP_APPROVAL_THRESHOLD=2
HC_APPROVAL_THRESHOLD=3

# Email — Brevo (primary, 300/day free tier)
BREVO_API_KEY=
BREVO_FROM_EMAIL=noreply@yourdomain.com

# Email — Mailjet (fallback, 200/day free tier)
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
MAILJET_FROM_EMAIL=noreply@yourdomain.com

# Reply-To address shown to recipients (should be a monitored clerk inbox)
REPLY_TO_EMAIL=clerk@yourdomain.com

# Google Calendar integration (optional — skip silently if not set)
# Place service account JSON at secrets/google-sa.json and uncomment the volume mount in docker-compose.yml
GOOGLE_SERVICE_ACCOUNT_FILE=/run/secrets/google-sa.json
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# CORS — set to your production domain(s), comma-separated
ALLOWED_ORIGINS=https://yourdomain.com

# Base URLs used in redirect responses and email links
FRONTEND_BASE_URL=https://yourdomain.com
BACKEND_BASE_URL=https://api.yourdomain.com
