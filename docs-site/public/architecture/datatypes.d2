# direction: up

User: {
  shape: sql_table
  id: str {constraint: primary_key}
  email: str {constraint: unique, index}
  password_hash: str
  force_password_reset: bool {constraint: default=true}
  fname: str
  lname: str
  active: bool {constraint: default=true}
  phone: str {constraint: nullable,unique}
  bio: str {constraint: nullable}
  profile_image: str {constraint: nullable}
}

Calling: {
  shape: sql_table
  id: str {constraint: primary_key}
  name: str
  max_slots: int
  system_defined: bool
  is_public: bool
}

UserCalling: {
  shape: sql_table
  id: str {constraint: primary_key}
  user_id: str {constraint: foreign_key}
  calling_id: str {constraint: foreign_key}
  slot_number: int
}

Permissions: {
  shape: sql_table
  id: str {constraint: primary_key}
  foreign_id: str {constraint: foreign_key}
  is_calling: bool
  scopes: int
}

UserSession: {
  shape: sql_table
  id: str {constraint: primary_key}
  user_id: str {constraint: foreign_key,index}
  token_hash: str {constraint: unique}
  ip_address: str
  user_agent: str
  created_at: datetime {constraint: default=current_timestamp}
  last_active_at: datetime {constraint: default=current_timestamp}
  expires_at: datetime
}

# Ward related datatypes
Ward: {
  shape: sql_table
  id: str {constraint: primary_key}
  name: str
}

# High Councilor related datatypes
Assignment: {
  shape: sql_table
  id: str {constraint: primary_key}
  high_councilor_id: str {constraint: foreign_key}
  responsibility: str  {constraint: nullable,comma separated}
  committee: str {constraint: nullable,comma separated}
}

SpeakingAssignment: {
  shape: sql_table
  id: int {constraint: primary_key}
  high_councilor_id: str {constraint: foreign_key}
  speaker2: str {constraint: nullable}
  ward_id: str {constraint: foreign_key}
  month: datetime
}

SpeakingTopic: {
  shape: sql_table
  id: int {constraint: primary_key}
  topic: str
  reference_material: str {constraint: nullable}
  month: datetime
}


# Calling Kanban related datatypes
KanbanUpdate: {
  shape: sql_table
  id: int {constraint: primary_key}
  proposal_id: int {constraint: foreign_key}
  updater_id: str {constraint: foreign_key}
  from_stage: str
  to_stage: str
  updated_at: datetime {constraint: default=current_timestamp}
}

CallingProposal: {
  shape: sql_table
  id: int {constraint: primary_key}
  fname: str
  lname: str
  spouse_name: str {constraint: nullable}
  proposed_calling: str
  ward_id: int {constraint: foreign_key}
  is_release: bool {constraint: default=false}
  submitted_at: datetime {constraint: default=current_timestamp}
  updated_at: datetime {constraint: default=current_timestamp}
}

CallingComment: {
  shape: sql_table
  id: int {constraint: primary_key}
  proposal_id: int {constraint: foreign_key}
  commenter_id: str {constraint: foreign_key}
  comment: str
  created_at: datetime {constraint: default=current_timestamp}
  edited_at: datetime {constraint: nullable}
}

CallingApproval: {
  shape: sql_table
  id: int {constraint: primary_key}
  proposal_id: int {constraint: foreign_key}
  approver_id: str {constraint: foreign_key}
  approved: bool
  decision_at: datetime {constraint: default=current_timestamp}
}

CallingInterview: {
  shape: sql_table
  id: int {constraint: primary_key}
  proposal_id: int {constraint: foreign_key}
  interviewer_id: str {constraint: foreign_key}
  interview_date: datetime
}

# Ward

Ward: {
  shape: sql_table
  id: str {constraint: primary_key}
  name: str
  bishop_id: int {constraint: foreign_key}
}

# Relationships based on common fields
UserCalling -> User : "joins"
UserCalling -> Calling : "joins"
Permissions.foreign_id -> User.id : "references"
Permissions.foreign_id -> Calling.id : "references"
UserSession.user_id -> User.id : "references"
Assignment.high_councilor_id -> UserCalling.id : "references"
SpeakingAssignment.high_councilor_id -> UserCalling.id : "references"
SpeakingAssignment.ward_id -> Ward.id : "references"

# Calling Kanban relationships
KanbanUpdate.proposal_id -> CallingProposal.id : "references"
KanbanUpdate.updater_id -> User.id : "references"
CallingComment.proposal_id -> CallingProposal.id : "references"
CallingComment.commenter_id -> User.id : "references"
CallingApproval.proposal_id -> CallingProposal.id : "references"
CallingApproval.approver_id -> User.id : "references"
CallingInterview.proposal_id -> CallingProposal.id : "references"
CallingInterview.interviewer_id -> User.id : "references"
CallingProposal.submitter -> User.id : "references"

SiteSettings: {
  shape: sql_table
  id: int {constraint: primary_key}
  stake_name: str
  stake_address: str
  contact_email: str
  reply_to_email: str
  hero_title: str
  hero_subtitle: str
  hero_image_url: str {constraint: nullable}
  logo_url: str {constraint: nullable}
  sacrament_times: str {constraint: json array}
  hidden_pages: str {constraint: json array}
}

AppointmentType: {
  shape: sql_table
  id: int {constraint: primary_key}
  name: str {constraint: unique}
  description: str
  duration_mins: int
  details: str
  icon_name: str
  is_active: bool
  display_order: int
  system_defined: bool
}

AvailabilityWindow: {
  shape: sql_table
  id: int {constraint: primary_key}
  user_id: int {constraint: foreign_key}
  day_of_week: int
  start_minute: int
  end_minute: int
  valid_from: date {constraint: nullable}
  valid_until: date {constraint: nullable}
  is_active: bool
}

AvailabilityException: {
  shape: sql_table
  id: int {constraint: primary_key}
  date: date {constraint: nullable}
  reason: str
  is_global: bool
  user_id: int {constraint: nullable, foreign_key}
  recurrence: str {constraint: nullable}
}

Booking: {
  shape: sql_table
  id: int {constraint: primary_key}
  appointment_type_id: int {constraint: foreign_key}
  interviewer_user_id: int {constraint: foreign_key}
  first_name: str
  last_name: str
  email: str
  phone: str
  booking_date: date
  start_minute_of_day: int
  end_minute_of_day: int
  status: str
  notes: str {constraint: nullable}
  confirmation_token: str {constraint: nullable}
}

BuildingReservation: {
  shape: sql_table
  id: int {constraint: primary_key}
  event_name: str
  event_description: str
  date: date
  start_time: str
  end_time: str
  rooms: str {constraint: json array}
  organizer_name: str
  organizer_email: str
  organizer_phone: str
  organization: str
  affiliation: str
  needs_access: bool
  status: str
  submitted_at: datetime
  reviewed_at: datetime {constraint: nullable}
  reviewed_by: int {constraint: nullable, foreign_key}
  denial_reason: str {constraint: nullable}
}

TempleRecommendConfig: {
  shape: sql_table
  id: int {constraint: primary_key}
  location_name: str
  location_address: str
  open_hours_text: str
  exception_note: str {constraint: nullable}
  timezone: str
  slot_buffer_mins: int
  booking_window_days: int
  booking_cutoff_hours: int
}

# Foreign key relationships for new tables
AvailabilityWindow.user_id -> User.id
AvailabilityException.user_id -> User.id
Booking.appointment_type_id -> AppointmentType.id
Booking.interviewer_user_id -> User.id
BuildingReservation.reviewed_by -> User.id