DISCORD_TOKEN=<Your Discord Bot Token Here>
# URL of the FastAPI backend.
# Use http://backend:8000 when running in Docker Compose (Docker service name).
# Use http://localhost:8000 for local development outside Docker.
BACKEND_URL=http://backend:8000
# Token the discordbot checks on incoming requests from the backend (Authorization: Bearer)
BACKEND_TOKEN=<Your shared secret token here>
