# Root-level environment file — used by docker-compose.yml
# Copy to .env and fill in your domain before deploying.

# Your stake's domain (e.g., mystake.org or stake.yourdomain.com)
# Caddy uses this to route traffic and automatically obtain Let's Encrypt TLS certificates.
# DNS A records must point to this server for: DOMAIN, api.DOMAIN, docs.DOMAIN
DOMAIN=yourstake.org
